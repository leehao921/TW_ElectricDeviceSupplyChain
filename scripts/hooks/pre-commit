#!/bin/bash
# Pre-commit hook: 若 commit 動到 vault/concepts/*.md 或 tests/*.py, 跑 test_alpha_concepts.py
# 阻止過時 thesis 進入 master.
#
# Bypass with: git commit --no-verify (use sparingly, eg 你已知 DB 暫時 down)

set -eo pipefail   # pipefail 關鍵:確保 pytest 失敗能傳遞

CHANGED=$(git diff --cached --name-only --diff-filter=ACM)

# 只有當動到 concept page 或 test 本身才跑
if echo "$CHANGED" | grep -qE '^(vault/concepts/.*\.md|tests/.*\.py)$'; then
    echo "[pre-commit] 偵測到 concept page / test 變更, 跑 thesis 驗證..."

    # 直接跑 pytest, 不要 pipe, exit code 直接傳遞
    if ! python3 -m pytest tests/test_alpha_concepts.py -x --tb=short -q; then
        echo ""
        echo "❌ Thesis 驗證失敗 — 概念頁 testable_claims 與 DB 真實數據不符"
        echo "   修正方法 (3 選 1):"
        echo "   (a) 修正 concept page Top 5 排序 (thesis 已過時)"
        echo "   (b) 調整 testable_claims threshold 反映現況"
        echo "   (c) git commit --no-verify (僅在 DB 暫時無法 query 時使用)"
        exit 1
    fi

    echo "[pre-commit] ✓ thesis 驗證通過"
fi

exit 0
